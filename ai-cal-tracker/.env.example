# ==========================================
# REQUIRED: FatSecret API Credentials
# Get them here: https://platform.fatsecret.com/
# ==========================================
EXPO_PUBLIC_FATSECRET_CLIENT_ID=your_fatsecret_client_id_here
EXPO_PUBLIC_FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret_here

# ==========================================
# Other APIs (for other app features, not food search)
# ==========================================
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_key_here
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_key_here
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
